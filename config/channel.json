    "volume_during_narration": 0.08,
    "volume_during_pause": 0.15,
    "default_mood": "mysterious"
  },

  "thumbnail": {
    "grid": "3x3",
    "background": "#1a1a1a"
  },

  "upload": {
    "category_id": "28",
    "default_tags": ["science", "explained", "theory", "universe", "physics", "mysteries"]
